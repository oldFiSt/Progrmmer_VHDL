module pkt2axil_top #(
    parameter   TDATA_WIDTH = 64,
    parameter  TKEEP_WIDTH = TDATA_WIDTH / 8,
    
    parameter  TLAST_WIDTH     = 1,
    parameter  TVALID_WIDTH    = 1,
    parameter  TUSER_WIDTH     = 8
) 
(
    input   logic                   clk           ,
    input   logic                   rstn          ,

    input   logic [TDATA_WIDTH-1:0] s_axis_tdata  , /* synthesis PAP_MARK_DEBUG="true" */   
    input   logic [TKEEP_WIDTH-1:0] s_axis_tkeep  , /* synthesis PAP_MARK_DEBUG="true" */
    input   logic [TUSER_WIDTH-1:0] s_axis_tuser  , /* synthesis PAP_MARK_DEBUG="true" */
    input   logic                   s_axis_tvalid , /* synthesis PAP_MARK_DEBUG="true" */
    output  logic                   s_axis_tready , /* synthesis PAP_MARK_DEBUG="true" */
    input   logic                   s_axis_tlast  , /* synthesis PAP_MARK_DEBUG="true" */

    output  logic [TDATA_WIDTH-1:0] m_axis_tdata  , /* synthesis PAP_MARK_DEBUG="true" */
    output  logic [TKEEP_WIDTH-1:0] m_axis_tkeep  , /* synthesis PAP_MARK_DEBUG="true" */
    output  logic [TUSER_WIDTH-1:0] m_axis_tuser  , /* synthesis PAP_MARK_DEBUG="true" */
    output  logic                   m_axis_tvalid , /* synthesis PAP_MARK_DEBUG="true" */
    input   logic                   m_axis_tready , /* synthesis PAP_MARK_DEBUG="true" */
    output  logic                   m_axis_tlast  , /* synthesis PAP_MARK_DEBUG="true" */

    // AXI-Lite Write Address Channel
    output  logic                   axil_awvalid , /* synthesis PAP_MARK_DEBUG="true" */
    input   logic                   axil_awready , /* synthesis PAP_MARK_DEBUG="true" */
    output  logic            [31:0] axil_awaddr  , /* synthesis PAP_MARK_DEBUG="true" */
    output  logic             [2:0] axil_awprot  , /* synthesis PAP_MARK_DEBUG="true" */

    // AXI-Lite Write Data Channel
    output  logic                   axil_wvalid  , /* synthesis PAP_MARK_DEBUG="true" */
    input   logic                   axil_wready  , /* synthesis PAP_MARK_DEBUG="true" */
    output  logic            [31:0] axil_wdata   , /* synthesis PAP_MARK_DEBUG="true" */
    output  logic             [3:0] axil_wstrb   , /* synthesis PAP_MARK_DEBUG="true" */

    // AXI-Lite Write Response Channel
    input   logic             [1:0] axil_bresp   , /* synthesis PAP_MARK_DEBUG="true" */
    input   logic                   axil_bvalid  , /* synthesis PAP_MARK_DEBUG="true" */
    output  logic                   axil_bready  , /* synthesis PAP_MARK_DEBUG="true" */

    // AXI-Lite Read Address Channel
    output  logic                   axil_arvalid , /* synthesis PAP_MARK_DEBUG="true" */
    input   logic                   axil_arready , /* synthesis PAP_MARK_DEBUG="true" */
    output  logic            [31:0] axil_araddr  , /* synthesis PAP_MARK_DEBUG="true" */
    output  logic             [2:0] axil_arprot  , /* synthesis PAP_MARK_DEBUG="true" */

    // AXI-Lite Read Data Channel
    input   logic            [31:0] axil_rdata   , /* synthesis PAP_MARK_DEBUG="true" */
    input   logic             [1:0] axil_rresp   , /* synthesis PAP_MARK_DEBUG="true" */
    input   logic                   axil_rvalid  , /* synthesis PAP_MARK_DEBUG="true" */
    output  logic                   axil_rready   /* synthesis PAP_MARK_DEBUG="true" */

);

logic [TDATA_WIDTH-1:0] cutter_s_axis_tdata  ;
logic [TKEEP_WIDTH-1:0] cutter_s_axis_tkeep  ;
logic [TUSER_WIDTH-1:0] cutter_s_axis_tuser  ;
logic                   cutter_s_axis_tvalid ;
logic                   cutter_s_axis_tready ;
logic                   cutter_s_axis_tlast  ;
logic [TDATA_WIDTH-1:0] binder_m_axis_tdata  ;
logic [TKEEP_WIDTH-1:0] binder_m_axis_tkeep  ;
logic                   binder_m_axis_tvalid ;
logic                   binder_m_axis_tready ;
logic [TUSER_WIDTH-1:0] binder_m_axis_tuser  ;
logic                   binder_m_axis_tlast  ;

logic                   cutter_error_flag;
logic             [7:0] cutter_error_code;
logic                   cutter_last_transaction;

logic [TUSER_WIDTH-1:0] tuser_reg;
always_ff @(posedge clk) begin
    if (s_axis_tvalid && s_axis_tlast) begin
        tuser_reg <= s_axis_tuser;
    end
end
pkt2axil_axis_fifo #
(
    .DEPTH(8192),
    .DATA_WIDTH(TDATA_WIDTH),
    .USER_ENABLE(1),
    .USER_WIDTH(TUSER_WIDTH),
    .FRAME_FIFO(0)
)
axis_fifo_rx
(
    .clk                (clk                 ),
    .rst                (!rstn               ),
    .s_axis_tdata       (s_axis_tdata        ),
    .s_axis_tkeep       (s_axis_tkeep        ),
    .s_axis_tvalid      (s_axis_tvalid       ),
    .s_axis_tready      (s_axis_tready       ),
    .s_axis_tlast       (s_axis_tlast        ),
    .s_axis_tuser       (s_axis_tuser        ),

    .m_axis_tdata       (cutter_s_axis_tdata ),
    .m_axis_tkeep       (cutter_s_axis_tkeep ),
    .m_axis_tvalid      (cutter_s_axis_tvalid),
    .m_axis_tready      (cutter_s_axis_tready),
    .m_axis_tlast       (cutter_s_axis_tlast ),
    .m_axis_tuser       (cutter_s_axis_tuser )
);

pkt2axil_cutter #(
    .TDATA_WIDTH(TDATA_WIDTH)
)
cutter_inst (
    .clk          (clk                    ),                                                 
    .rstn         (rstn                   ),                                               
    .s_axis_tdata (cutter_s_axis_tdata    ),                                               
    .s_axis_tkeep (cutter_s_axis_tkeep    ),                                               
    .s_axis_tready(cutter_s_axis_tready   ),                                               
    .s_axis_tvalid(cutter_s_axis_tvalid   ),                                             
    .s_axis_tlast (cutter_s_axis_tlast    ),            

    .axil_awvalid (axil_awvalid           ),                                                                                           
    .axil_awaddr  (axil_awaddr            ),                                                 
    .axil_awready (axil_awready           ),                                               
    .axil_awprot  (axil_awprot            ),                                                 
    .axil_wvalid  (axil_wvalid            ),                                                                                                
    .axil_wdata   (axil_wdata             ),                                           
    .axil_wready  (axil_wready            ),                                               
    .axil_wstrb   (axil_wstrb             ),                                                                                     
    .axil_arvalid (axil_arvalid           ),                                               
    .axil_arready (axil_arready           ),                                               
    .axil_araddr  (axil_araddr            ),                                                                                                
    .axil_arprot  (axil_arprot            ),
    
    .error_flag   (cutter_error_flag      ),
    .error_code   (cutter_error_code      ),
    .last_transaction(cutter_last_transaction)
);

pkt2axil_binder #(
    .TDATA_WIDTH(TDATA_WIDTH),
    .TUSER_WIDTH(TUSER_WIDTH)
)
binder_inst
(
    .clk           (clk                 ),
    .rstn          (rstn                ),

    .m_axis_tdata  (binder_m_axis_tdata  ),
    .m_axis_tkeep  (binder_m_axis_tkeep  ),
    .m_axis_tuser  (binder_m_axis_tuser  ), 
    .m_axis_tvalid (binder_m_axis_tvalid ),
    .m_axis_tready (binder_m_axis_tready ),
    .m_axis_tlast  (binder_m_axis_tlast  ),

    .axil_bresp    (axil_bresp          ),
    .axil_bvalid   (axil_bvalid         ),
    .axil_bready   (axil_bready         ),

    .axil_rdata    (axil_rdata          ),
    .axil_rresp    (axil_rresp          ),
    .axil_rvalid   (axil_rvalid         ),
    .axil_rready   (axil_rready         ),
    
    .error_flag    (cutter_error_flag   ),
    .error_code    (cutter_error_code[1:0]),
    .last_transaction(cutter_last_transaction),
    
    .axil_awaddr   (axil_awaddr         ),
    .axil_awvalid  (axil_awvalid        ),
    .axil_awready  (axil_awready        ),
    .axil_araddr   (axil_araddr         ),
    .axil_arvalid  (axil_arvalid        ),
    .axil_arready  (axil_arready        )

);

pkt2axil_axis_fifo #
(
    .DEPTH(8192),
    .DATA_WIDTH(TDATA_WIDTH),
    .USER_ENABLE(1),
    .USER_WIDTH(TUSER_WIDTH),
    .FRAME_FIFO(1)
)
axis_fifo_tx
(
    .clk                (clk                    ),
    .rst                (!rstn                  ),

    .s_axis_tdata       (binder_m_axis_tdata    ),
    .s_axis_tkeep       (binder_m_axis_tkeep    ),
    .s_axis_tvalid      (binder_m_axis_tvalid   ),
    .s_axis_tready      (binder_m_axis_tready   ),
    .s_axis_tuser       (binder_m_axis_tuser    ),
    .s_axis_tlast       (binder_m_axis_tlast    ),

    .m_axis_tdata       (m_axis_tdata           ),
    .m_axis_tkeep       (m_axis_tkeep           ),
    .m_axis_tvalid      (m_axis_tvalid          ),
    .m_axis_tready      (m_axis_tready          ),
    .m_axis_tlast       (m_axis_tlast           ),
    .m_axis_tuser       (m_axis_tuser           )
);

endmodule

